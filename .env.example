# ──────────────────────────────────────────────
#  VacantIA — Variables de entorno
#  Copiá este archivo a .env y completá los valores
# ──────────────────────────────────────────────

# OBLIGATORIO — clave secreta para firmar sesiones
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-en-produccion

# URL pública de la app (sin barra final)
# En Render: https://tu-app.onrender.com
# En local:  http://localhost:8000
BASE_URL=http://localhost:8000

# Directorio donde se guardan las bases de datos SQLite
# En Render free tier se pierde al reiniciar; agregar Persistent Disk para produccion real
DATA_DIR=./data

# ── Turso (SQLite en la nube — persistencia en Render free tier) ──
# Sin esto, en Render free los datos se BORRAN en cada reinicio/deploy (SQLite local efímero).
# 1. Crea una DB gratis en https://turso.tech  (turso db create jobagent)
# 2. URL:   turso db show jobagent --url        →  libsql://...turso.io
# 3. Token: turso db tokens create jobagent
# Si quedan vacías, la app usa SQLite local automáticamente (fallback seguro).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Opcional: DB separada para vacantes/aplicaciones (el tracker usa esta y, si no,
# cae a TURSO_DATABASE_URL). Dejar vacío para usar la misma DB.
TURSO_JOBS_DATABASE_URL=

# ── IA ──────────────────────────────────────────
# Obtene tu key gratis en https://console.groq.com
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXX

# ── Portales de empleo ───────────────────────────
COMPUTRABAJO_EMAIL=tu@email.com
COMPUTRABAJO_PASSWORD=tu_password

BUMERAN_EMAIL=tu@email.com
BUMERAN_PASSWORD=tu_password

ZONAJOBS_EMAIL=tu@email.com
ZONAJOBS_PASSWORD=tu_password

# ── Notificaciones Telegram (opcional) ──────────
# Crea un bot en @BotFather y obten el token
# El chat_id es tu ID personal (podés verlo en @userinfobot)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── Email transaccional (forgot-password) ────────
# Registrate gratis en https://resend.com (100 emails/dia gratis)
# Verifica tu dominio o usa onboarding@resend.dev para pruebas
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXX
RESEND_FROM=VacantIA <noreply@vacantia.app>

# ── Servidor ─────────────────────────────────────
PORT=8000

# ── Monetizacion ─────────────────────────────────
# Cantidad de búsquedas gratuitas antes de pedir upgrade
FREE_RUNS_LIMIT=3

# Admin secret para upgrade manual: POST /api/admin/upgrade -H "X-Admin-Secret: XXX"
# Genera uno con: python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_SECRET=

# ── Mercado Pago ─────────────────────────────────
# 1. Entra a https://www.mercadopago.com.ar/developers/panel/app
# 2. Crea una aplicacion o usa una existente
# 3. En "Credenciales de produccion" copia el Access Token
#    Para pruebas usa las "Credenciales de prueba" (empieza con TEST-)
MP_ACCESS_TOKEN=

# Precio mensual en pesos argentinos (default 14990)
MP_PRICE_ARS=14990

# Secret para validar firma de webhooks (opcional pero recomendado en produccion)
# Lo encontras en: panel MP → tu app → Webhooks → ver clave secreta
MP_WEBHOOK_SECRET=

# ── Soporte ──────────────────────────────────────
SUPPORT_WHATSAPP=5491112345678
SUPPORT_EMAIL=hola@vacantia.app

# ── Tunel ngrok (opcional, solo local) ──────────
# Registrate gratis en https://dashboard.ngrok.com y pega tu token
NGROK_AUTHTOKEN=
