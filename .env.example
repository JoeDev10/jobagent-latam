# ── IA ──────────────────────────────────────────────────────────────────────
# Gratis en console.groq.com
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXX

# ── Credenciales de portales ─────────────────────────────────────────────────
# Creá una cuenta en cada portal antes de correr el bot

COMPUTRABAJO_EMAIL=tu@email.com
COMPUTRABAJO_PASSWORD=tu_password

BUMERAN_EMAIL=tu@email.com
BUMERAN_PASSWORD=tu_password

ZONAJOBS_EMAIL=tu@email.com
ZONAJOBS_PASSWORD=tu_password

# ── Telegram (notificaciones) ─────────────────────────────────────────────────
# 1. Hablá con @BotFather en Telegram → /newbot → copiá el token
# 2. Mandá un mensaje a tu bot, luego abrí:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    para obtener tu chat_id
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── General ───────────────────────────────────────────────────────────────────
APP_NAME=JobAgent LATAM
DEBUG=false
LOG_LEVEL=INFO
HEADLESS=true
SLOW_MO=50
MAX_APPLICATIONS_PER_DAY=30
MIN_DELAY_BETWEEN_ACTIONS=2
MAX_DELAY_BETWEEN_ACTIONS=5
